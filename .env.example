# ============================================================
# AI 위치안내 서비스 환경변수 예시 파일
# ============================================================
# 이 파일에는 실제 인증키를 입력하지 마세요.
# 로컬에서 사용할 때 이 파일을 복사해 `.env` 파일을 만들고,
# `.env`에만 실제 인증키를 입력하세요.
# 실제 `.env` 파일은 GitHub에 올리면 안 됩니다.

# ------------------------------------------------------------
# 서버 기본 설정
# ------------------------------------------------------------

# 로컬 서버가 사용할 포트 번호입니다.
PORT=3000

# ------------------------------------------------------------
# 카카오맵 API
# ------------------------------------------------------------

# 카카오 Developers에서 발급받은 JavaScript 키입니다.
# 카카오 Developers의 플랫폼 > Web 사이트 도메인도 함께 등록해야 합니다.
KAKAO_MAP_APP_KEY=

# ------------------------------------------------------------
# 행정안전부 대한민국 공공서비스(혜택) 정보 API
# ------------------------------------------------------------

# 정부·지자체·공공기관의 지원 혜택, 신청 조건, 준비서류를 조회합니다.
MOIS_PUBLIC_SERVICE_API_KEY=

# ------------------------------------------------------------
# 소상공인시장진흥공단 상가(상권)정보 API
# ------------------------------------------------------------

# 주변 카페, 병원, 약국 등 상가의 상호명·업종·주소·좌표를 조회합니다.
# 영업시간이나 공휴일 운영 여부는 이 API만으로 판단하지 않습니다.
SEMAS_STORE_API_KEY=

# ------------------------------------------------------------
# 국립중앙의료원 의료기관 운영정보 API
# ------------------------------------------------------------
# 공공데이터포털에서 아래 API를 각각 활용신청해야 합니다.
# 같은 일반 인증키가 표시되더라도 서비스별 변수로 나누어 관리합니다.

# 전국 병·의원 찾기 서비스 인증키입니다.
# 병원·의원 위치, 진료과목, 요일별 진료시간, 공휴일 진료 정보를 조회합니다.
NMC_HOSPITAL_API_KEY=

# 전국 약국 정보 조회 서비스 인증키입니다.
# 약국 위치, 전화번호, 요일별 운영시간, 공휴일 운영 정보를 조회합니다.
NMC_PHARMACY_API_KEY=

# 전국 명절 비상 진료기관 정보 조회 서비스 인증키입니다.
# 설날·추석 등 명절에 진료하는 병원과 운영하는 약국을 조회합니다.
NMC_HOLIDAY_MEDICAL_API_KEY=

# 전국 응급의료기관 정보 조회 서비스 인증키입니다.
# 실시간 응급실 가용병상과 중증질환 수용 가능 정보를 조회합니다.
NMC_EMERGENCY_API_KEY=

